# Copy to .env and fill in. With these blank, the app runs in MOCK mode
# (deterministic stub responses, no Azure calls) so you can demo offline.

# Azure AI Vision (Image Analysis 4.0 / Read) — verbatim OCR
VISION_ENDPOINT=
VISION_KEY=

# Azure OpenAI (GPT-4o vision) — OCR-grounded field assignment
AOAI_ENDPOINT=
AOAI_KEY=
AOAI_DEPLOYMENT=gpt-4o
AOAI_API_VERSION=2024-10-21
# Image detail sent to the VLM: "low" (default) is faster and, grounded on OCR
# text, more accurate on small print than "high".
AOAI_IMAGE_DETAIL=low

# Force mock mode even if creds are present (handy for demos)
MOCK_VISION=false
# Production guard: refuse to start in mock mode (no silent fabricated verdicts)
REQUIRE_AZURE=false

# Limits / abuse controls
BATCH_CONCURRENCY=8
MAX_UPLOAD_MB=10
MAX_BATCH_FILES=400
RATE_LIMIT_PER_MIN=60
